// server/tsconfig.json

{

  "compilerOptions": {

    "target": "ES2022",

    "module": "commonjs",

    "lib": ["ES2022"],

    "outDir": "./dist",

    "rootDir": "./src",

    "strict": true,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "resolveJsonModule": true,

    "declaration": true,

    "declarationMap": true,

    "sourceMap": true,

    "baseUrl": "./src",

    "paths": {
      "@/*": ["./src/*"]
    },

    "types": ["jest", "node"],

    "ignoreDeprecations": "6.0"

  },
  
  "include": ["src/**/*"],

  "exclude": ["node_modules", "dist", "__tests__"]

}